<Application
    x:Class="RongYokDownloader.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:RongYokDownloader.Converters"
    xmlns:vm="clr-namespace:RongYokDownloader.ViewModels"
    xmlns:views="clr-namespace:RongYokDownloader.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- converters -->
            <conv:UrlToImageConverter x:Key="UrlToImage" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
            <conv:StatusToBrushConverter x:Key="StatusToBrush" />
            <conv:FileExistsConverter x:Key="FileExists" />

            <!-- page VM -> View mapping (rendered by the shell's ContentControl) -->
            <DataTemplate DataType="{x:Type vm:CatalogViewModel}">
                <views:CatalogView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SeriesDetailViewModel}">
                <views:SeriesDetailView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DownloadsViewModel}">
                <views:DownloadsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:LibraryViewModel}">
                <views:LibraryView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PlayerViewModel}">
                <views:PlayerView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
