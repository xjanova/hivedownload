<Window
    x:Class="RongYokDownloader.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:RongYokDownloader.Converters"
    Title="Hive Download — Smart Media Downloader"
    Height="820" Width="1280"
    MinHeight="600" MinWidth="1000"
    WindowStartupLocation="CenterScreen"
    Icon="/Assets/logo.png"
    FontFamily="{StaticResource AppFont}"
    Background="{StaticResource BgBase}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ============================ sidebar ============================ -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">

                <!-- brand (logo) -->
                <StackPanel DockPanel.Dock="Top" Margin="16,14,16,10">
                    <Image Source="/Assets/logo.png" Stretch="Uniform" Width="198" HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="ดูดซีรี่ส์จีน · rongyok.com" Style="{StaticResource Muted}"
                               HorizontalAlignment="Center" Margin="0,2,0,0" />
                </StackPanel>

                <!-- footer -->
                <TextBlock DockPanel.Dock="Bottom" Margin="24,0,24,18" Style="{StaticResource Muted}"
                           TextWrapping="Wrap" Text="v1.0 · เพื่อการใช้งานส่วนตัว&#x0a;แหล่งข้อมูล: rongyok.com" />

                <!-- nav -->
                <ListBox x:Name="Nav" Margin="0,8,0,0" Background="Transparent" BorderThickness="0"
                         SelectedIndex="{Binding SelectedNavIndex, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource NavItem}">
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B2;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="26" />
                            <TextBlock Text="คลังซีรี่ส์" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="26" />
                                <TextBlock Text="คิวดาวน์โหลด" VerticalAlignment="Center" />
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="999" Background="{StaticResource Accent}"
                                    Padding="7,1" MinWidth="22"
                                    Visibility="{Binding ActiveDownloads, Converter={StaticResource NotEmptyToVis}}">
                                <TextBlock Text="{Binding ActiveDownloads}" Foreground="{StaticResource AccentInk}" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="26" />
                            <TextBlock Text="คลังของฉัน" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="26" />
                            <TextBlock Text="ตั้งค่า" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="26" />
                                <TextBlock Text="NetWix Sync" VerticalAlignment="Center" />
                            </StackPanel>
                            <Ellipse HorizontalAlignment="Right" VerticalAlignment="Center" Width="9" Height="9"
                                     Visibility="{Binding NetWixConnected, Converter={StaticResource BoolToVis}}">
                                <Ellipse.Fill><SolidColorBrush Color="#46D369" /></Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                    </ListBoxItem>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ============================ content ============================ -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" />
    </Grid>
</Window>
