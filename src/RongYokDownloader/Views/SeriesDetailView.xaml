<UserControl
    x:Class="RongYokDownloader.Views.SeriesDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:RongYokDownloader.ViewModels"
    xmlns:conv="clr-namespace:RongYokDownloader.Converters"
    FontFamily="{StaticResource AppFont}">

    <UserControl.Resources>
        <!-- episode selection chip -->
        <Style x:Key="EpChip" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Width" Value="80" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" CornerRadius="9" Background="#B3121219"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <Grid>
                                <TextBlock x:Name="lbl" Text="{Binding Label}" Foreground="{StaticResource TextSecondary}"
                                           FontSize="12.5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource Accent}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                           Margin="0,5,6,0"
                                           Visibility="{Binding IsDownloaded, Converter={StaticResource BoolToVis}}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource BgHover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource RgbBrush}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource RgbBrush}" />
                                <Setter TargetName="lbl" Property="Foreground" Value="White" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ambient blurred backdrop of the SAME clip — fills the "empty" sides beautifully at any size -->
        <MediaElement x:Name="BgBlur" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="UniformToFill"
                      Volume="0" Opacity="0" IsHitTestVisible="False" MediaFailed="Bg_MediaFailed">
            <MediaElement.Effect>
                <BlurEffect Radius="46" KernelType="Gaussian" RenderingBias="Performance" />
            </MediaElement.Effect>
        </MediaElement>
        <!-- crisp FULL vertical frame, centred, with feathered edges so it melts into the backdrop -->
        <!-- feathered edges applied in code-behind (see UpdateFeatherMask) so it's even on all sides -->
        <MediaElement x:Name="BgA" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Volume="0.8" Opacity="0" IsHitTestVisible="False" SizeChanged="BgA_SizeChanged"
                      MediaOpened="Bg_MediaOpened" MediaEnded="Bg_MediaEnded" MediaFailed="Bg_MediaFailed" />

        <!-- scrim: clear at the top (show the video), dark at the bottom (readable content) -->
        <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1A08080B" Offset="0" />
                    <GradientStop Color="#3308080B" Offset="0.42" />
                    <GradientStop Color="#B8080810" Offset="0.66" />
                    <GradientStop Color="#F5080810" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <TextBlock x:Name="PrepHint" Text="กำลังเตรียมตัวอย่าง EP.1…" IsHitTestVisible="False"
                   Foreground="{StaticResource TextMuted}" FontSize="12"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />

        <!-- content -->
        <Grid Margin="26,16,26,20">

            <!-- back (top-left, floats over the video) -->
            <StackPanel VerticalAlignment="Top" Orientation="Horizontal">
                <Button Style="{StaticResource GhostButton}" Command="{Binding BackCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="กลับ" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="16,0,0,0" />
            </StackPanel>

            <!-- ALL info anchored to the bottom; the top stays free for the video -->
            <Grid VerticalAlignment="Bottom" MaxWidth="1180" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- poster (kept on the left) -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" ClipToBounds="True"
                        Width="158" Height="232" VerticalAlignment="Bottom" Margin="0,0,20,0">
                    <Image conv:ImageLoader.SourceUrl="{Binding Series.DisplayImageUrl}" Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom">

                <!-- title -->
                <TextBlock Text="{Binding Series.CleanTitle}" Style="{StaticResource H1}" TextWrapping="Wrap" />

                <!-- meta + primary actions -->
                <Grid Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="6" Background="#CC241247" Padding="9,3">
                            <TextBlock Text="{Binding Series.TypeThai}" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource AccentHover}" />
                        </Border>
                        <TextBlock Text="{Binding Series.YearText}" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="12,0,0,0" />
                        <TextBlock Text="·" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="10,0" />
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="13">
                            <Run Text="{Binding Episodes.Count, Mode=OneWay}" /><Run Text=" ตอน" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="⬇  ดาวน์โหลดทั้งเรื่อง" Style="{StaticResource PrimaryButton}" Padding="16,10" Command="{Binding DownloadAllCommand}" />
                        <Button Content="เลือกที่ยังไม่มี" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Command="{Binding SelectRemainingCommand}" />
                    </StackPanel>
                </Grid>

                <!-- synopsis (short) -->
                <TextBlock Text="{Binding Series.Description}" Style="{StaticResource Muted}" FontSize="13"
                           TextWrapping="Wrap" LineHeight="21" MaxHeight="64" TextTrimming="CharacterEllipsis" Margin="0,12,0,0" />

                <!-- episode selection toolbar -->
                <Grid Margin="0,16,0,10">
                    <TextBlock Text="เลือกตอนที่จะดาวน์โหลด" Style="{StaticResource H2}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="เลือกทั้งหมด" Style="{StaticResource MiniButton}" Command="{Binding SelectAllCommand}" />
                        <Button Content="ไม่เลือก" Style="{StaticResource MiniButton}" Command="{Binding SelectNoneCommand}" />
                        <Button Content="สลับ" Style="{StaticResource MiniButton}" Command="{Binding InvertSelectionCommand}" />
                        <Button Padding="16,8" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}"
                                Command="{Binding DownloadSelectedCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ดาวน์โหลดที่เลือก (" />
                                <TextBlock Text="{Binding SelectedCount}" />
                                <TextBlock Text=")" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- episode chips (capped height, scrolls) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="184" Padding="0,0,8,0">
                    <ItemsControl ItemsSource="{Binding Episodes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:EpisodeSelectItem}">
                                <ToggleButton Style="{StaticResource EpChip}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              ToolTip="ดับเบิลคลิกเพื่อดูเลย · คลิกเดียวเพื่อเลือกดาวน์โหลด"
                                              PreviewMouseLeftButtonDown="Episode_PreviewDown" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
