<Window
    x:Class="RongYokDownloader.Views.WhatsNewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:RongYokDownloader.ViewModels"
    xmlns:models="clr-namespace:RongYokDownloader.Models"
    xmlns:conv="clr-namespace:RongYokDownloader.Converters"
    Title="ของใหม่ · RongYok"
    Height="680" Width="760"
    MinHeight="400" MinWidth="560"
    WindowStartupLocation="CenterOwner"
    FontFamily="{StaticResource AppFont}"
    Background="{StaticResource BgBase}">

    <DockPanel Margin="24,20,24,20">

        <!-- header -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,18">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="มีอะไรใหม่" Style="{StaticResource H1}" />
                </StackPanel>
                <TextBlock Text="{Binding Headline}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource MiniButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding CloseCommand}" />
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>

                <!-- new series -->
                <StackPanel Visibility="{Binding HasNewSeries, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="🎬  ซีรี่ส์ใหม่" Style="{StaticResource H2}" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding NewSeries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NewSeriesItem}">
                                <Border Style="{StaticResource Card}" Width="158" Margin="0,0,14,14" Padding="0" ClipToBounds="True">
                                    <StackPanel>
                                        <Border CornerRadius="14,14,0,0" Background="{StaticResource BgElevated}" ClipToBounds="True" Height="210">
                                            <Image conv:ImageLoader.SourceUrl="{Binding Series.DisplayImageUrl}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Margin="10,9,10,11">
                                            <TextBlock Text="{Binding Series.CleanTitle}" FontSize="12.5" FontWeight="SemiBold"
                                                       TextWrapping="Wrap" MaxHeight="36" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Series.TypeThai}" Style="{StaticResource Muted}" Margin="0,3,0,0" />
                                            <Grid Margin="0,9,0,0">
                                                <Button Style="{StaticResource PrimaryButton}" Padding="0" Height="32" Content="⬇ ดาวน์โหลด"
                                                        Command="{Binding DataContext.DownloadSeriesCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding Queued, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                                <Border Height="32" CornerRadius="9" Background="{StaticResource BgElevated}"
                                                        Visibility="{Binding Queued, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="✓ อยู่ในคิว" Foreground="{StaticResource AccentHover}" FontSize="12"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                            <Button Content="ดูรายละเอียด" Style="{StaticResource MiniButton}" HorizontalAlignment="Center" Margin="0,4,0,0"
                                                    Command="{Binding DataContext.OpenSeriesCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Series}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- new episodes -->
                <StackPanel Margin="0,10,0,0" Visibility="{Binding HasUpdates, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="🆕  ตอนใหม่ (เรื่องที่คุณโหลดไว้)" Style="{StaticResource H2}" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Updates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:EpisodeUpdateItem}">
                                <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="46" Height="62" CornerRadius="7" Background="{StaticResource BgElevated}" ClipToBounds="True" Margin="0,0,14,0">
                                            <Image conv:ImageLoader.SourceUrl="{Binding Series.DisplayImageUrl}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Series.CleanTitle}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Summary}" Foreground="{StaticResource AccentHover}" FontSize="12.5" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <Grid Grid.Column="2" VerticalAlignment="Center">
                                            <Button Style="{StaticResource PrimaryButton}" Padding="16,9" Content="⬇ โหลดตอนใหม่"
                                                    Command="{Binding DataContext.DownloadNewEpisodesCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding Queued, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                            <TextBlock Text="✓ อยู่ในคิว" Foreground="{StaticResource AccentHover}" FontSize="13" VerticalAlignment="Center"
                                                       Visibility="{Binding Queued, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Button Content="ปิด" Style="{StaticResource GhostButton}" HorizontalAlignment="Center" Margin="0,14,0,0" Padding="40,10"
                        Command="{Binding CloseCommand}" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
