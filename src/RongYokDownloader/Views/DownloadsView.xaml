<UserControl
    x:Class="RongYokDownloader.Views.DownloadsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:RongYokDownloader.ViewModels"
    FontFamily="{StaticResource AppFont}">

    <DockPanel Margin="28,24,28,0">

        <!-- header -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="คิวดาวน์โหลด" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding Summary}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Content="หยุดทั้งหมด" Style="{StaticResource GhostButton}" Command="{Binding PauseAllCommand}" />
                <Button Content="เล่นต่อทั้งหมด" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Command="{Binding ResumeAllCommand}" />
                <Button Content="ล้างที่เสร็จแล้ว" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Command="{Binding ClearCompletedCommand}" />
            </StackPanel>
        </Grid>

        <!-- empty state -->
        <TextBlock DockPanel.Dock="Top" Text="ยังไม่มีรายการในคิว — เลือกเรื่องจาก 'คลังซีรี่ส์' แล้วกดดาวน์โหลด"
                   Margin="2,20,0,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Jobs.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- queue -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <ItemsControl ItemsSource="{Binding Jobs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DownloadJob}">
                        <Border Style="{StaticResource Card}" Padding="16,13" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- status dot -->
                                <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="2,0,14,0"
                                         Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />

                                <!-- middle: title + progress -->
                                <StackPanel Grid.Column="1">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding SeriesTitle}" FontWeight="SemiBold" FontSize="13.5" />
                                            <TextBlock Text="  ·  " Foreground="{StaticResource TextMuted}" />
                                            <TextBlock Text="{Binding EpisodeLabel}" Foreground="{StaticResource TextSecondary}" FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="{StaticResource TextSecondary}">
                                            <Run Text="{Binding StatusText, Mode=OneWay}" />
                                            <Run Text=" " />
                                            <Run Text="{Binding PercentText, Mode=OneWay}" Foreground="{StaticResource TextPrimary}" />
                                        </TextBlock>
                                    </Grid>

                                    <ProgressBar Style="{StaticResource JadeProgress}" Minimum="0" Maximum="1" Margin="0,9,0,7"
                                                 Value="{Binding Progress, Mode=OneWay}" />

                                    <Grid>
                                        <TextBlock Text="{Binding SizeText}" Style="{StaticResource Muted}" />
                                        <TextBlock Text="{Binding SpeedText}" Style="{StaticResource Muted}" HorizontalAlignment="Right" />
                                    </Grid>
                                    <TextBlock Text="{Binding Error}" Foreground="{StaticResource Danger}" FontSize="11.5" Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding Error, Converter={StaticResource NotEmptyToVis}}" />
                                </StackPanel>

                                <!-- right: controls -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <Button ToolTip="หยุดชั่วคราว" Style="{StaticResource MiniButton}"
                                            Content="&#xE769;" FontFamily="Segoe MDL2 Assets"
                                            Command="{Binding DataContext.PauseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding CanPause, Converter={StaticResource BoolToVis}}" />
                                    <Button ToolTip="ดาวน์โหลดต่อ" Style="{StaticResource MiniButton}"
                                            Content="&#xE768;" FontFamily="Segoe MDL2 Assets"
                                            Command="{Binding DataContext.ResumeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding CanResume, Converter={StaticResource BoolToVis}}" />
                                    <Button ToolTip="ลบออกจากคิว" Style="{StaticResource MiniButton}" Margin="4,0,0,0"
                                            Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource Danger}"
                                            Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
