<UserControl
    x:Class="RongYokDownloader.Views.CatalogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:RongYokDownloader.Models"
    xmlns:conv="clr-namespace:RongYokDownloader.Converters"
    FontFamily="{StaticResource AppFont}">

    <DockPanel Margin="28,24,28,0" LastChildFill="True">

        <!-- header -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="คลังซีรี่ส์" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding ResultSummary}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <!-- scan status (left of the buttons) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                        <ProgressBar Width="60" Height="3" IsIndeterminate="True" Foreground="{StaticResource Accent}"
                                     Background="Transparent" BorderThickness="0" Margin="0,0,10,0"
                                     Visibility="{Binding DataContext.IsScanning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding DataContext.ScanStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Style="{StaticResource Muted}" VerticalAlignment="Center" MaxWidth="340" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding DataContext.ScanForNewCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="สแกนหาของใหม่" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Content="⟳  รีเฟรช" Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                            Command="{Binding RefreshCommand}" IsEnabled="{Binding IsNotBusy}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- search + filters -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
            <!-- source picker (โรงหยก / wow-drama / …) -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="แหล่ง" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <ListBox Style="{StaticResource ChipList}" ItemsSource="{Binding SourceNames}"
                         SelectedIndex="{Binding SelectedSourceIndex, Mode=TwoWay}" />
            </StackPanel>

            <Grid>
                <TextBox x:Name="Search" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}" />
                <TextBlock Text="ค้นหาชื่อเรื่อง…" Foreground="{StaticResource TextMuted}" Margin="12,0,0,0"
                           VerticalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <ListBox Style="{StaticResource ChipList}" SelectedIndex="{Binding TypeFilterIndex, Mode=TwoWay}">
                    <ListBoxItem Content="ทั้งหมด" />
                    <ListBoxItem Content="พากย์ไทย" />
                    <ListBoxItem Content="ซับไทย" />
                </ListBox>
                <Border Width="1" Background="{StaticResource Border}" Margin="6,4,14,4" />
                <ListBox Style="{StaticResource ChipList}" SelectedIndex="{Binding SortIndex, Mode=TwoWay}">
                    <ListBoxItem Content="ล่าสุด" />
                    <ListBoxItem Content="ยอดนิยม" />
                    <ListBoxItem Content="ชื่อเรื่อง" />
                </ListBox>
            </StackPanel>
        </StackPanel>

        <!-- busy strip -->
        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3" Margin="0,0,0,8"
                     Foreground="{StaticResource Accent}" Background="Transparent" BorderThickness="0"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

        <!-- grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Series}">
                            <Button Width="182" Margin="0,0,16,18" Cursor="Hand" BorderThickness="0" Background="Transparent"
                                    Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="card" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                                            <StackPanel>
                                                <Grid Height="252">
                                                    <Border CornerRadius="14,14,0,0" Background="{StaticResource BgElevated}" ClipToBounds="True">
                                                        <Image conv:ImageLoader.SourceUrl="{Binding DisplayImageUrl}"
                                                               Stretch="UniformToFill" />
                                                    </Border>
                                                    <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="8"
                                                            CornerRadius="6" Background="#CC241247" Padding="7,3">
                                                        <TextBlock Text="{Binding TypeThai}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentHover}" />
                                                    </Border>
                                                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8"
                                                            CornerRadius="6" Background="#B0000000" Padding="7,3">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE7C8;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                       Foreground="#E5E7EB" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                            <TextBlock Text="{Binding ViewCountText}" FontSize="11" Foreground="#E5E7EB" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                                <StackPanel Margin="12,10,12,14">
                                                    <TextBlock Text="{Binding CleanTitle}" FontSize="13.5" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" MaxHeight="40" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding YearText}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="card" Property="BorderBrush" Value="{DynamicResource RgbBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="โหลดเพิ่ม" Style="{StaticResource GhostButton}" HorizontalAlignment="Center"
                        Margin="0,4,0,28" Padding="40,10" Command="{Binding LoadMoreCommand}"
                        Visibility="{Binding CanLoadMore, Converter={StaticResource BoolToVis}}" />

                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Muted}" HorizontalAlignment="Center" Margin="0,0,0,20" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
