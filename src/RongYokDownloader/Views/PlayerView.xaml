<UserControl
    x:Class="RongYokDownloader.Views.PlayerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:RongYokDownloader.ViewModels"
    FontFamily="{StaticResource AppFont}">

    <UserControl.Resources>
        <!-- episode row in the player's playlist (tap to play if downloaded, else tap to download) -->
        <Style x:Key="PlaylistItem" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="ToolTip" Value="คลิกเพื่อเล่น (ถ้ายังไม่โหลด จะโหลดให้ทันที)" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- default state = not downloaded -->
                                <TextBlock x:Name="icon" Grid.Column="0" Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" />
                                <TextBlock x:Name="label" Grid.Column="1" Text="{Binding Label}" Margin="8,0,0,0"
                                           VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource BgHover}" />
                            </Trigger>
                            <!-- downloaded → playable -->
                            <DataTrigger Binding="{Binding IsPlayable}" Value="True">
                                <Setter TargetName="icon" Property="Text" Value="&#xE768;" />
                                <Setter TargetName="icon" Property="Foreground" Value="{StaticResource AccentHover}" />
                                <Setter TargetName="label" Property="Foreground" Value="{StaticResource TextSecondary}" />
                            </DataTrigger>
                            <!-- queued / downloading -->
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter TargetName="icon" Property="Text" Value="&#xE896;" />
                                <Setter TargetName="icon" Property="Foreground" Value="{StaticResource Cyan}" />
                                <Setter TargetName="label" Property="Foreground" Value="{StaticResource Cyan}" />
                                <Setter Property="ToolTip" Value="กำลังดาวน์โหลด…" />
                            </DataTrigger>
                            <!-- now playing -->
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource BgElevated}" />
                                <Setter TargetName="icon" Property="Text" Value="&#xE768;" />
                                <Setter TargetName="icon" Property="Foreground" Value="{StaticResource Accent}" />
                                <Setter TargetName="label" Property="Foreground" Value="{StaticResource TextPrimary}" />
                                <Setter TargetName="label" Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="16" />
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="0">

        <!-- top bar -->
        <Grid DockPanel.Dock="Top" Margin="20,16,20,10">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource GhostButton}" Command="{Binding BackCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="กลับ" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding CurrentTitle}" Style="{StaticResource H2}" VerticalAlignment="Center" Margin="16,0,0,0" />
            </StackPanel>
            <Button x:Name="TheaterBtn" HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                    Content="โรงหนัง" Click="ToggleTheater_Click" />
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- video + transport -->
            <Border Grid.Column="0" Background="Black" CornerRadius="14" Margin="20,0,10,20" ClipToBounds="True">
                <Grid x:Name="VideoArea" Background="Transparent" MouseMove="Video_MouseMove">
                    <MediaElement x:Name="Media" LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  ScrubbingEnabled="True" Stretch="Uniform"
                                  MediaOpened="Media_MediaOpened" MediaEnded="Media_MediaEnded" MediaFailed="Media_MediaFailed" />

                    <!-- empty hint -->
                    <TextBlock x:Name="EmptyHint" Text="เลือกตอนจากรายการด้านขวาเพื่อเล่น"
                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <!-- transport overlay (auto-hides while playing) -->
                    <Border x:Name="ControlsBar" VerticalAlignment="Bottom" Background="#B0000000" Padding="14,10">
                        <StackPanel>
                            <Grid>
                                <TextBlock x:Name="CurTime" Text="0:00" Foreground="#E5E7EB" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock x:Name="DurTime" Text="0:00" Foreground="#E5E7EB" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                            <Slider x:Name="Seek" Margin="0,4,0,4" Minimum="0" Maximum="1" IsMoveToPointEnabled="True"
                                    Foreground="{StaticResource Accent}" />
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="&#xE892;" Style="{StaticResource TransportBtn}" ToolTip="ก่อนหน้า" Command="{Binding PreviousCommand}" />
                                    <Button x:Name="PlayPauseBtn" Content="&#xE768;" Style="{StaticResource TransportBtn}" FontSize="22" Click="PlayPause_Click" />
                                    <Button Content="&#xE893;" Style="{StaticResource TransportBtn}" ToolTip="ถัดไป" Command="{Binding NextCommand}" />
                                    <Button Content="&#xE71A;" Style="{StaticResource TransportBtn}" ToolTip="หยุด" Click="Stop_Click" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" Foreground="#E5E7EB" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <Slider x:Name="Vol" Width="90" Minimum="0" Maximum="1" Value="0.9" VerticalAlignment="Center"
                                            Foreground="{StaticResource Accent}" ValueChanged="Vol_ValueChanged" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- playlist -->
            <Border x:Name="Sidebar" Grid.Column="1" Width="276" Margin="0,0,20,20" CornerRadius="16"
                    BorderThickness="1" BorderBrush="{StaticResource Border}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#17171F" Offset="0" />
                        <GradientStop Color="#0C0C12" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="16,16,16,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="4" Height="20" CornerRadius="2" Background="{DynamicResource RgbBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="สารบัญตอน" Style="{StaticResource H2}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- glass settings card with toggle switches -->
                        <Border CornerRadius="13" Background="#101017" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                Padding="14,4" Margin="0,13,0,8">
                            <StackPanel>
                                <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding StreamMode}" Margin="0,9,0,9">
                                    <StackPanel>
                                        <TextBlock Text="โหมดสตรีม" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="ดูเลย ไม่เก็บไฟล์" Style="{StaticResource Muted}" FontSize="10.5" />
                                    </StackPanel>
                                </CheckBox>
                                <Border Height="1" Background="{StaticResource Border}" Opacity="0.55" />
                                <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding Prefetch}" Margin="0,9,0,9">
                                    <StackPanel>
                                        <TextBlock Text="โหลดล่วงหน้า" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="แอบโหลดตอนถัดไปรอ" Style="{StaticResource Muted}" FontSize="10.5" />
                                    </StackPanel>
                                </CheckBox>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="แตะที่ตอนเพื่อเล่น/โหลดทันที" Style="{StaticResource Muted}" FontSize="11"
                                   Margin="2,0,0,2" TextWrapping="Wrap" />
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,4,10">
                        <ItemsControl ItemsSource="{Binding Episodes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:PlayerEpisode}">
                                    <Button Style="{StaticResource PlaylistItem}" HorizontalAlignment="Stretch"
                                            Command="{Binding DataContext.PlayEpisodeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            PreviewMouseLeftButtonDown="PlaylistItem_PreviewDown" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
